    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agro Forte - Futuro Sustentável</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>

<header>
    <h1>🌱 Agro Forte: Futuro Sustentável</h1>
    <p>Equilíbrio entre produção e meio ambiente</p>
</header>

<main>
    <div class="painel">
        <h2>Indicadores</h2>

        <p>Produção: <span id="producao">50</span>%</p>
        <p>Meio Ambiente: <span id="ambiente">50</span>%</p>

        <div class="botoes">
            <button onclick="aduboQuimico()">Usar Adubo Químico</button>

            <button onclick="agriculturaSustentavel()">
                Agricultura Sustentável
            </button>

            <button onclick="economizarAgua()">
                Economizar Água
            </button>
        </div>

        <h3 id="resultado"></h3>
    </div>
</main>

<script src="js/script.js"></script>
</body>
</html>