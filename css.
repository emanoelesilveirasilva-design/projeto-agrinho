*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#e8f5e9;
    text-align:center;
}

header{
    background:#2e7d32;
    color:white;
    padding:20px;
}

.painel{
    background:white;
    width:80%;
    max-width:600px;
    margin:30px auto;
    padding:25px;
    border-radius:15px;
    box-shadow:0 0 10px rgba(0,0,0,0.2);
}

p{
    margin:15px;
    font-size:20px;
}

button{
    margin:10px;
    padding:12px 18px;
    border:none;
    border-radius:10px;
    cursor:pointer;
    background:#43a047;
    color:white;
    font-size:16px;
}

button:hover{
    background:#2e7d32;
}

#resultado{
    margin-top:20px;
}